# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://talos:talos@localhost:11112/talos

# ─── LLM keys (at least one required) ────────────────────────────────────────
# OPENROUTER_API_KEY unlocks all catalog models via OpenRouter.
# Without it, set the provider key that matches each model (OpenAI / Anthropic / Gemini).
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Model configuration (defaults shown) ────────────────────────────────────
# Agent: vision + reasoning for browser automation steps
AGENT_MODEL=openai/gpt-4.1-mini
# Post-run holistic + filmstrip screenshot analysis
REVIEW_AGENT_MODEL=gemini-2.5-flash
# Crawl, path plans, intents (legacy fallbacks if unset: SCRIPT_MODEL, SUMMARY_MODEL, REVIEW_MODEL)
# Text/JSON auxiliary stack (crawl, path plans, memory curation, intents). CRAWL_MODEL is a deprecated alias.
AUXILIARY_MODEL=gemini-2.5-flash

# ─── Stagehand (optional) ────────────────────────────────────────────────────
STAGEHAND_ENABLED=true
STAGEHAND_MODEL=google/gemini-2.0-flash

# ─── Security ──────────────────────────────────────────────────────────────────
# Optional: AES-256-GCM key for encrypting stored credentials (64 hex chars / 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When unset, credentials are stored in plaintext (backwards compatible).
# ENCRYPTION_KEY=

# ─── Redis (required for run queue) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=11111
APP_URL=http://localhost:11111
RUN_TIMEOUT_MINUTES=15

# UiPath Test Cloud integration
# Set to true when running inside a UiPath Automation Cloud/Test Cloud environment.
UIPATH_TEST_CLOUD_ENABLED=false
# modern uses the current UiPath CLI. legacy supports older uipcli installs.
# custom lets you provide UIPATH_TEST_CLOUD_ARGS with placeholders.
UIPATH_TEST_CLOUD_MODE=modern
UIPATH_CLI_PATH=uip
UIPATH_ORCHESTRATOR_URL=
UIPATH_ORCHESTRATOR_TENANT=
# Optional in modern mode because UiPath derives the project from TEST_SET_KEY prefix.
UIPATH_TEST_CLOUD_PROJECT_KEY=
UIPATH_TEST_CLOUD_TEST_SET_KEY=
UIPATH_TEST_CLOUD_EXECUTION_TYPE=manual
UIPATH_TEST_CLOUD_WAIT=false
UIPATH_TEST_CLOUD_TIMEOUT_SECONDS=600
UIPATH_TEST_CLOUD_OUTPUT_DIR=
# Optional CLI-specific flags, for example auth profile, folder, or organization options.
UIPATH_TEST_CLOUD_EXTRA_ARGS=
# Custom mode placeholders: {inputPath}, {payloadPath}, {junitPath}, {resultPath}, {runId}, {status}, {projectKey}, {testSetKey}, {tenant}, {orchestratorUrl}
UIPATH_TEST_CLOUD_ARGS=
